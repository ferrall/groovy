# Groovy Environment Variables Example
# Copy this file to .env.local and update with your values

# Analytics Domain (analytics only loads on this domain)
VITE_ANALYTICS_DOMAIN=bahar.co.il

# Analytics Script URL
VITE_ANALYTICS_SCRIPT_URL=https://www.bahar.co.il/assets/universal-analytics.js

# Base Path for deployment (set in vite.config.ts or here)
# VITE_BASE_PATH=/scribe/

# URL Shortener API (for Share modal)
# The key is a publishable (bundle-safe) pk_live_ key, origin-scoped server-side;
# it may appear in the public bundle. For local development use the SEPARATE
# development publishable key (origins http://localhost:*), NOT the production key.
# VITE_URL_SHORTENER_API=https://go.bahar.co.il
# VITE_URL_SHORTENER_PUBLISHABLE_KEY=pk_live_your_publishable_key_here
